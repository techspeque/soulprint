# Auth.js — generate with: npx auth secret
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# Resend (magic link email delivery)
RESEND_API_KEY=
EMAIL_FROM=noreply@yourdomain.com

# OpenRouter (AI analysis)
OPENROUTER_API_KEY=

# App URL (used for OpenRouter referer header)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Vercel KV (auto-set when KV store is linked in Vercel)
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
